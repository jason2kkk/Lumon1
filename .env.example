# ===== GPT 配置（系统内置，所有用户共享） =====
# 部署时需填入真实的 GPT URL/Key/Model
GPT_BASE_URL=https://your-proxy.example.com/v1
GPT_API_KEY=sk-your-gpt-key
GPT_MODEL=gpt-5.4-mini

# ===== Claude 配置（可选，用户自行配置） =====
CLAUDE_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# ===== 搜索引擎（可选） =====
TAVILY_API_KEY=

# ===== 飞书集成（可选） =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ===== 外部 CLI 数据接口（供同事调用） =====
# 用于保护 /api/cli/* 端点，同事请求时需带 X-API-Key header
CLI_API_KEY=
